{
  "name": "akp-architekten-atlas",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node -e \"const port = process.env.PORT || '3000'; process.argv = ['node', 'next', 'start', '-H', '0.0.0.0', '-p', port]; require('./node_modules/next/dist/bin/next');\"",
    "typecheck": "tsc --noEmit",
    "test:ci": "node --test tests/*.test.mjs",
    "ci": "npm run test:ci && npm run typecheck && npm run build"
  },
  "dependencies": {
    "next": "15.0.7",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "typescript": "^5"
  },
  "engines": {
    "node": "20.x"
  }
}
